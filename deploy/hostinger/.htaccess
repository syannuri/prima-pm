# Prismatix SPA — Hostinger Business Web (LiteSpeed) — frontend of the split deploy.
# Upload the CONTENTS of client/dist into public_html (of the app. subdomain) together
# with this file. It forces HTTPS and routes every client-side path to index.html.

RewriteEngine On

# Force HTTPS (Hostinger provisions a free Let's Encrypt cert per subdomain in hPanel).
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SPA fallback: anything that is not a real file/dir is handled by the React router.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]

<IfModule mod_headers.c>
  # Never cache the app shell or the service worker → a new deploy is picked up at once.
  <FilesMatch "(^index\.html$|sw\.js$|\.webmanifest$)">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Fingerprinted build assets (Vite emits hashed filenames) can be cached forever.
  <FilesMatch "-[A-Za-z0-9]{8,}\.(js|css|woff2?|ttf|png|jpe?g|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Baseline security headers for the static origin (the API sets its own via helmet).
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "same-origin"
  Header always set X-Frame-Options "DENY"
</IfModule>
