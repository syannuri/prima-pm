# ─────────────────────────────────────────────────────────────────────────────
# Prismatix API — backend env for a SPLIT deploy (Railway / Render / small VPS).
#
# HOW TO USE (Railway): open your service → Variables → "Raw Editor" → paste all
# the KEY=VALUE lines below → replace every REPLACE_… placeholder and example.com.
#   • Service root directory:  server/
#   • Build command:           npm ci && npm run build
#   • Start command:           node dist/server.js
#   • After first deploy, run:  npx prisma migrate deploy   (Railway shell / one-off)
#
# ⚠️ This is a TEMPLATE — never commit real secrets. Comment lines (starting with #)
#    are ignored; delete them before pasting if your platform is strict.
# ─────────────────────────────────────────────────────────────────────────────

# --- Required ---------------------------------------------------------------
NODE_ENV=production

# PostgreSQL connection string.
#   • Neon/Supabase: copy from the dashboard and KEEP the ?sslmode=require suffix.
#   • Railway Postgres plugin: use the reference value  ${{Postgres.DATABASE_URL}}
DATABASE_URL=REPLACE_WITH_YOUR_POSTGRES_URL

# Two DIFFERENT secrets. Generate each with:  openssl rand -hex 48
JWT_ACCESS_SECRET=REPLACE_WITH_openssl_rand_hex_48
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_openssl_rand_hex_48

# --- Split-deploy wiring ----------------------------------------------------
# Served over HTTPS at the platform edge → turns on HSTS + Secure cookies.
SECURE=true

# Behind the platform's reverse proxy, so req.ip reads the real client
# (per-IP rate-limits + audit log stay accurate).
TRUST_PROXY=1

# EXACT origin of the frontend, no trailing slash. Replace example.com with your domain.
CORS_ORIGIN=https://app.example.com

# Leading-dot registrable domain → shares the JS-readable prima_csrf cookie across
# app.example.com and api.example.com (required, or every mutation 403s). Must be the
# SAME registrable domain as CORS_ORIGIN so cookies stay same-site (SameSite=Strict).
COOKIE_DOMAIN=.example.com

# --- Do NOT set -------------------------------------------------------------
# PORT   → injected by Railway/Render; the app binds it automatically.
# HOST   → defaults to 0.0.0.0 (correct for a PaaS). Only set for a custom bind.

# --- Optional (defaults shown) ----------------------------------------------
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=7d
