# Copy to server/.env for a production deploy and fill in real values.
# IMPORTANT: generate long random secrets (e.g. `openssl rand -hex 32`).

NODE_ENV=production
PORT=4000

# PostgreSQL connection (the LAN box runs Postgres locally on :5432).
DATABASE_URL=postgresql://prima:prima@localhost:5432/prima_pm?schema=public

# JWT signing secrets — REPLACE THESE.
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# In production the client is served from this same origin, so CORS is not needed.
# Set this only if you serve the frontend from a different host/port.
CORS_ORIGIN=http://localhost:4000

# Optional: override the built client location (defaults to ../client/dist).
# CLIENT_DIST_PATH=/home/mamed/prima-pm/client/dist
