# Copy to server/.env for a production deploy and fill in real values.
# IMPORTANT: generate long random secrets (e.g. `openssl rand -hex 32`).

NODE_ENV=production
PORT=4000
# Bind to loopback so ONLY the reverse proxy (nginx) can reach the app port; the Node
# port must never be directly reachable from the internet. Defaults to 0.0.0.0 if unset.
HOST=127.0.0.1

# PostgreSQL connection (the LAN box runs Postgres locally on :5432).
DATABASE_URL=postgresql://prima:prima@localhost:5432/prima_pm?schema=public

# JWT signing secrets — REPLACE THESE.
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS allowlist (comma-separated). In production the client is served from the same
# origin, but set this to the PUBLIC HTTPS origin so cross-tool/API calls are accepted.
# During a http-LAN→https transition you may list both, e.g.:
#   CORS_ORIGIN=https://pm.example.com,http://192.168.1.150:4000
CORS_ORIGIN=https://pm.example.com

# Turn ON once served over HTTPS behind a TLS proxy: enables HSTS + upgrade-insecure-requests.
# MUST stay unset/false on a plain-http LAN deploy (it would blank the page over http).
SECURE=true
# Trust N reverse-proxy hops so req.ip is the real client (the login rate-limiter keys on
# it). Set to the number of proxies in front (1 for a single nginx). Leave UNSET on a
# direct bind — trusting a spoofable X-Forwarded-For would defeat the limiter.
TRUST_PROXY=1

# Optional: override the built client location (defaults to ../client/dist).
# CLIENT_DIST_PATH=/home/mamed/prima-pm/client/dist
