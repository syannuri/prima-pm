// =====================================================================
// PRIMA-PM — Prisma Schema
// Integrated Project Management Web Application
// DB: PostgreSQL 16 | Money: Decimal(18,2) | Generated: 2026-06-27
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

enum Role {
  ADMIN
  PMO
  PROJECT_MANAGER
  FINANCE
  RISK_OFFICER
  TEAM_MEMBER
  VIEWER
}

enum ProjectStatus {
  DRAFT
  CHARTERED
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum ProjectCategory {
  NETWORK_INFRA
  SERVER_INFRA
  CLOUD_INFRA
  CYBERSECURITY_INFRA
  APP_DEV
}

enum ChangeMagnitude {
  MINOR
  MAJOR
}

enum ChangeImpact {
  COST
  SCHEDULE
  RESOURCE
  QUALITY
  RISK
}

enum DirectCostType {
  TECHNOLOGY_ONPREM
  TECHNOLOGY_CLOUD
  HARDWARE_LICENSE
  SOFTWARE_LICENSE
  MANPOWER
}

enum PersonnelRole {
  PM
  PROJECT_PERSONNEL
}

enum IndirectCostType {
  TRANSPORTATION
  ACCOMMODATION
  ENTERTAINMENT
}

enum RiskKind {
  THREAT
  OPPORTUNITY
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  IDENTIFIED
  ANALYZING
  PLANNED
  OPEN
  CLOSED
  OCCURRED
}

enum ResponseStrategy {
  AVOID
  MITIGATE
  TRANSFER
  ACCEPT
  EXPLOIT
  ENHANCE
  SHARE
}

enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish
}

enum ChangeRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// Delivery methodology for a project (predictive/waterfall, agile, or hybrid).
enum DeliveryApproach {
  PREDICTIVE
  AGILE
  HYBRID
}

enum BacklogType {
  EPIC
  STORY
  TASK
  BUG
}

// Board columns for an agile work item.
enum BacklogStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum AttachmentOwner {
  CHARTER
  RISK
  PROJECT
  TASK
}

// =====================================================================
// CORE / IDENTITY
// =====================================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  changesSeenAt DateTime? // last time this user viewed the change-notification feed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  managedProjects   Project[]       @relation("ProjectManager")
  charters          ProjectCharter[] @relation("CharterPM")
  ownedRisks        Risk[]          @relation("RiskOwner")
  ownedIssues       Issue[]         @relation("IssueOwner")
  assignedTasks     Task[]          @relation("TaskPIC")
  manpowerItems     CostItemDirect[] @relation("ManpowerResource")
  auditLogs         AuditLog[]
  changeRequests    ChangeRequest[] @relation("CRRequester")
  reviewedCRs       ChangeRequest[] @relation("CRReviewer")
  decidedCRs        ChangeRequest[] @relation("CRDecider")
  resourceProfiles  Resource[]      @relation("ResourceUser")
  assignedBacklog   BacklogItem[]   @relation("BacklogAssignee")
  notifications     Notification[]  @relation("UserNotifications")

  @@index([role])
}

// =====================================================================
// PROJECT + CHARTER (Module 1)
// =====================================================================

model Project {
  id        String        @id @default(uuid())
  code      String        @unique
  name      String
  clientName String?      // the client/customer the project is delivered for
  sponsor   String?
  category        ProjectCategory?
  costBaselineIdr Decimal? @db.Decimal(18, 2) // high-level planning cost baseline
  totalRevenueIdr Decimal? @db.Decimal(18, 2) // expected total revenue
  status    ProjectStatus @default(DRAFT)
  deliveryApproach DeliveryApproach @default(PREDICTIVE)
  pmUserId  String?
  pm        User?         @relation("ProjectManager", fields: [pmUserId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  scheduleBaselinedAt DateTime? // when the schedule baseline was last captured

  charter          ProjectCharter?
  charterVersions  CharterVersion[]
  directCosts      CostItemDirect[]
  indirectCosts    CostItemIndirect[]
  risks            Risk[]
  issues           Issue[]
  tasks            Task[]
  costBaseline     CostBaseline?
  changeRequests   ChangeRequest[]
  attachments      Attachment[]
  actualCosts      ActualCostEntry[]
  sprints          Sprint[]
  backlogItems     BacklogItem[]

  @@index([status])
  @@index([pmUserId])
}

model ProjectCharter {
  id              String          @id @default(uuid())
  projectId       String          @unique
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  description     String
  goals           String
  category        ProjectCategory
  hiScope         String
  hiCostIdr       Decimal         @db.Decimal(18, 2)
  hiScheduleStart DateTime
  hiScheduleEnd   DateTime
  hiDeliverables  String

  pmUserId        String
  pm              User            @relation("CharterPM", fields: [pmUserId], references: [id])

  version         Int             @default(1)
  locked          Boolean         @default(false)
  committedAt     DateTime?
  committedBy     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
}

// Immutable snapshot taken on each Commit (versioning + audit)
model CharterVersion {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  committedBy String
  committedAt DateTime @default(now())

  @@unique([projectId, version])
  @@index([projectId])
}

// =====================================================================
// COST MANAGEMENT (Module 2)
// =====================================================================

// Unified Direct Cost line (Material rows + Manpower rows), discriminated by `type`
model CostItemDirect {
  id        String         @id @default(uuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      DirectCostType
  label     String

  // --- Material fields (TECHNOLOGY_*, HARDWARE_LICENSE, SOFTWARE_LICENSE) ---
  qty       Decimal?       @db.Decimal(18, 2)
  unitCost  Decimal?       @db.Decimal(18, 2)
  amount    Decimal?       @db.Decimal(18, 2) // = qty * unitCost

  // --- Manpower fields (type = MANPOWER) ---
  personnelRole     PersonnelRole?
  resourceUserId    String?
  resource          User?          @relation("ManpowerResource", fields: [resourceUserId], references: [id])
  rateCardId        String?
  rateCard          RateCard?      @relation(fields: [rateCardId], references: [id])
  unitCostPerManday Decimal?       @db.Decimal(18, 2)
  planMandays       Decimal?       @db.Decimal(10, 2)
  manpowerCost      Decimal?       @db.Decimal(18, 2) // = unitCostPerManday * planMandays

  // Link to schedule task (manpower <-> schedule sync)
  task   Task?   @relation("TaskManpower", fields: [taskId], references: [id])
  taskId String?

  // Link to the resource master (manpower pool). Preferred over the legacy
  // resourceUserId; supplies the day-rate and personnel role.
  resourceRef Resource? @relation("LineResource", fields: [resourceId], references: [id])
  resourceId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, type])
}

model CostItemIndirect {
  id          String           @id @default(uuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        IndirectCostType
  description String
  amount      Decimal          @db.Decimal(18, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId, type])
}

model RateCard {
  id                String           @id @default(uuid())
  roleName          String
  level             String?
  unitCostPerManday Decimal          @db.Decimal(18, 2)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  directCosts CostItemDirect[]
  resources   Resource[]

  @@unique([roleName, level])
}

// ---------------------------------------------------------------------------
// Resource master (manpower pool). A Resource is a person or a generic role
// available to projects; it is NOT a login account (optionally linked to one
// via userId). Picked when loading manpower into the WBS / Cost module.
// ---------------------------------------------------------------------------
enum ResourceType {
  NAMED // a specific person
  GENERIC // a role / placeholder (e.g. "Senior QA Engineer")
}

model Resource {
  id            String        @id @default(uuid())
  name          String
  resourceType  ResourceType  @default(NAMED)
  roleTitle     String? // free-text job title, e.g. "Backend Engineer"
  personnelRole PersonnelRole @default(PROJECT_PERSONNEL)

  // Costing: an effective day-rate, optionally sourced from a rate card.
  rateCardId        String?
  rateCard          RateCard? @relation(fields: [rateCardId], references: [id])
  unitCostPerManday Decimal   @default(0) @db.Decimal(18, 2)

  // Capacity: mandays available per working day (0.5 = half-time, 3 = a crew of 3).
  capacityPerDay Decimal @default(1) @db.Decimal(6, 2)

  department String?

  // Optional link to a system account (for resources who also log in).
  userId String?
  user   User?   @relation("ResourceUser", fields: [userId], references: [id])

  costLines CostItemDirect[] @relation("LineResource")
  picTasks  Task[]           @relation("TaskPicResource")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// Computed roll-up cache (1:1 with Project)
model CostBaseline {
  id                 String   @id @default(uuid())
  projectId          String   @unique
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  directTotal        Decimal  @default(0) @db.Decimal(18, 2)
  indirectTotal      Decimal  @default(0) @db.Decimal(18, 2)
  contingencyReserve Decimal  @default(0) @db.Decimal(18, 2)
  managementReserve  Decimal  @default(0) @db.Decimal(18, 2)
  costBaseline       Decimal  @default(0) @db.Decimal(18, 2) // direct + indirect + contingency
  budgetAtCompletion Decimal  @default(0) @db.Decimal(18, 2) // costBaseline + managementReserve

  updatedAt          DateTime @updatedAt
}

// Time-phased Actual Cost (AC) entries — cumulative AC up to a status date
// drives the Cost Performance Index (CPI) in EVM.
model ActualCostEntry {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date        DateTime
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  recordedBy  String?
  createdAt   DateTime @default(now())

  @@index([projectId, date])
}

// =====================================================================
// RISK MANAGEMENT (Module 3)
// =====================================================================

model Risk {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?
  category    String?
  status      RiskStatus @default(IDENTIFIED)
  kind        RiskKind   @default(THREAT)

  ownerUserId String?
  owner       User?      @relation("RiskOwner", fields: [ownerUserId], references: [id])

  // --- Qualitative ---
  probabilityScore Int          // 1..5
  impactScore      Int          // 1..5
  riskScore        Int          // = probabilityScore * impactScore
  severity         RiskSeverity

  // --- Quantitative (EMV) ---
  probabilityPct Decimal  @db.Decimal(5, 4) // 0..1
  impactCostIdr  Decimal  @db.Decimal(18, 2)
  emv            Decimal  @db.Decimal(18, 2) // = probabilityPct * impactCostIdr

  // --- Response ---
  responseStrategy ResponseStrategy?
  responseCost     Decimal?          @db.Decimal(18, 2)
  residualEmv      Decimal?          @db.Decimal(18, 2)
  includeInReserve Boolean           @default(true)

  attachments Attachment[] @relation("RiskAttachments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, severity])
}

enum IssueImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Issue Log — problems that have already occurred (distinct from Risk, which is
// a potential future event). Lightweight register: no EVM/reserve impact.
model Issue {
  id          String      @id @default(uuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?
  category    String?
  impact      IssueImpact @default(MEDIUM)
  status      IssueStatus @default(OPEN)

  ownerUserId String?
  owner       User?       @relation("IssueOwner", fields: [ownerUserId], references: [id])

  resolution  String?     @db.Text
  raisedAt    DateTime    @default(now()) // when the issue was logged/occurred
  resolvedAt  DateTime?                   // auto-stamped when status → RESOLVED/CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

// =====================================================================
// SCHEDULE MANAGEMENT (Module 4)
// =====================================================================

model Task {
  id           String    @id @default(uuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentTaskId String?
  parent       Task?     @relation("TaskTree", fields: [parentTaskId], references: [id])
  subtasks     Task[]    @relation("TaskTree")

  wbsCode      String
  name         String
  // WBS dictionary — descriptive detail for each work package.
  description        String? @db.Text
  deliverable        String? @db.Text
  acceptanceCriteria String? @db.Text
  planStart    DateTime
  planEnd      DateTime
  // Schedule baseline snapshot (for variance / tracking Gantt).
  baselineStart  DateTime?
  baselineFinish DateTime?
  actualStart  DateTime?
  actualFinish DateTime?

  picUserId    String?
  pic          User?     @relation("TaskPIC", fields: [picUserId], references: [id])

  // Owner / person-in-charge picked from the resource master (preferred over picUserId).
  picResourceId String?
  picResource   Resource? @relation("TaskPicResource", fields: [picResourceId], references: [id])

  progressPct  Int       @default(0) // 0..100
  isMilestone  Boolean   @default(false)
  sortOrder    Int       @default(0)

  // schedule <-> cost (manpower) link
  manpowerItems CostItemDirect[] @relation("TaskManpower")

  // dependencies
  predecessorOf TaskDependency[] @relation("DepPredecessor")
  successorOf   TaskDependency[] @relation("DepSuccessor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, parentTaskId])
}

model TaskDependency {
  id            String         @id @default(uuid())
  predecessorId String
  predecessor   Task           @relation("DepPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     Task           @relation("DepSuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  type          DependencyType @default(FS)
  lagDays       Int            @default(0)

  @@unique([predecessorId, successorId])
}

// =====================================================================
// GOVERNANCE: CHANGE CONTROL, AUDIT, ATTACHMENTS
// =====================================================================

model ChangeRequest {
  id          String              @id @default(uuid())
  projectId   String
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String // e.g. CHARTER, COST_BASELINE, SCHEDULE, SCOPE
  title       String
  description String

  chargeable  Boolean             @default(false) // paid (billable) vs no-cost change
  amountIdr   Decimal?            @db.Decimal(18, 2) // billable amount (only when chargeable)
  magnitude   ChangeMagnitude     @default(MINOR)
  impactAreas ChangeImpact[]      // areas affected: cost/schedule/resource/quality/risk

  status      ChangeRequestStatus @default(SUBMITTED)
  requestedBy String
  requester   User                @relation("CRRequester", fields: [requestedBy], references: [id])
  reviewedBy  String?
  reviewer    User?               @relation("CRReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  decidedBy   String?
  decider     User?               @relation("CRDecider", fields: [decidedBy], references: [id])
  decidedAt   DateTime?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([projectId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  projectId String? // set for project-scoped events (enables per-project audit view)
  entity    String
  entityId  String
  action    String // CREATE | UPDATE | DELETE | COMMIT | APPROVE | REJECT
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([projectId, createdAt])
  @@index([createdAt])
}

model Attachment {
  id         String          @id @default(uuid())
  ownerType  AttachmentOwner
  ownerId    String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  uploadedBy String
  createdAt  DateTime        @default(now())

  // optional typed back-relations (kept loose/polymorphic by ownerType)
  project    Project? @relation(fields: [projectRelId], references: [id])
  projectRelId String?
  risk       Risk?    @relation("RiskAttachments", fields: [riskRelId], references: [id])
  riskRelId  String?

  @@index([ownerType, ownerId])
}

// ---- Agile ----

// A time-boxed iteration (Scrum). Optional for Kanban projects (items can live in
// the product backlog / on the board without a sprint).
model Sprint {
  id        String       @id @default(uuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  name      String
  goal      String?      @db.Text
  startDate DateTime?
  endDate   DateTime?
  status    SprintStatus @default(PLANNED)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items     BacklogItem[]
  snapshots SprintSnapshot[]

  @@index([projectId])
}

// Daily snapshot of a sprint's remaining vs committed story points — powers the
// burndown chart (recorded when the board is fetched, deduped per day).
model SprintSnapshot {
  id               String   @id @default(uuid())
  sprintId         String
  sprint           Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  date             DateTime @db.Date
  committedPoints  Int      @default(0)
  remainingPoints  Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([sprintId, date])
  @@index([sprintId])
}

// Persistent per-user in-app notification (inbox) — for discrete events like being
// assigned as a project's PM (not the on-demand "needs attention" alerts).
model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id])
  type      String    // e.g. PROJECT_ASSIGNED
  title     String
  body      String?   @db.Text
  projectId String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

// A product-backlog work item (epic/story/task/bug). `sprintId` null = product
// backlog; when in a sprint it shows on the board by `status`.
model BacklogItem {
  id                 String        @id @default(uuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id])
  sprintId           String?
  sprint             Sprint?       @relation(fields: [sprintId], references: [id])
  type               BacklogType   @default(STORY)
  title              String
  description        String?       @db.Text
  acceptanceCriteria String?       @db.Text
  storyPoints        Int?
  priority           Int           @default(0) // MoSCoW-ish rank; lower = higher priority
  status             BacklogStatus @default(TODO)
  assigneeUserId     String?
  assignee           User?         @relation("BacklogAssignee", fields: [assigneeUserId], references: [id])
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([projectId])
  @@index([sprintId])
}
