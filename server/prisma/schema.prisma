// =====================================================================
// PRIMA-PM — Prisma Schema
// Integrated Project Management Web Application
// DB: PostgreSQL 16 | Money: Decimal(18,2) | Generated: 2026-06-27
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

enum Role {
  ADMIN
  PMO
  PROJECT_MANAGER
  FINANCE
  RISK_OFFICER
  TEAM_MEMBER
  VIEWER
  // Self-service guest: self-signs up, sees/manages ONLY their own personal projects
  // (Project.personalOwnerId == their id), self-governs them with no approval matrix.
  GUEST
}

enum ProjectStatus {
  DRAFT
  CHARTERED
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum ProjectCategory {
  NETWORK_INFRA
  SERVER_INFRA
  CLOUD_INFRA
  CYBERSECURITY_INFRA
  APP_DEV
  DATACENTER
  ENTERPRISE_APP
  SYSTEM_INTEGRATION
  DATA_ANALYTICS
  AI_ML
  DIGITAL_TRANSFORMATION
  MANAGED_SERVICES
  IT_CONSULTING
  OTHER
}

enum ChangeMagnitude {
  MINOR
  MAJOR
}

enum ChangeImpact {
  CHARTER
  COST
  SCHEDULE
  RESOURCE
  QUALITY
  RISK
}

enum DirectCostType {
  TECHNOLOGY_ONPREM
  TECHNOLOGY_CLOUD
  HARDWARE_LICENSE
  SOFTWARE_LICENSE
  MANPOWER
  SUBCONTRACTOR
  TRAINING_CERTIFICATION
  SUPPORT_MAINTENANCE
  HARDWARE_EQUIPMENT
  OTHER
}

enum PersonnelRole {
  PM
  PROJECT_PERSONNEL
}

// Splits an Actual Cost entry into the direct/indirect budget it draws down, so
// "remaining Direct vs Indirect" can be computed (AC is otherwise uncategorised).
// Labour-from-timesheet AC is always DIRECT.
enum CostCategory {
  DIRECT
  INDIRECT
}

enum IndirectCostType {
  TRANSPORTATION
  ACCOMMODATION
  ENTERTAINMENT
  MEALS_PERDIEM
  COMMUNICATION
  OFFICE_SUPPLIES
  MEETING_VENUE
  OTHER
}

enum RiskKind {
  THREAT
  OPPORTUNITY
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  IDENTIFIED
  ANALYZING
  PLANNED
  OPEN
  CLOSED
  OCCURRED
}

enum ResponseStrategy {
  AVOID
  MITIGATE
  TRANSFER
  ACCEPT
  EXPLOIT
  ENHANCE
  SHARE
}

enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish
}

enum ChangeRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// Delivery methodology for a project (predictive/waterfall, agile, or hybrid).
enum DeliveryApproach {
  PREDICTIVE
  AGILE
  HYBRID
}

enum BacklogType {
  EPIC
  STORY
  TASK
  BUG
}

// Board columns for an agile work item.
enum BacklogStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum AttachmentOwner {
  CHARTER
  RISK
  PROJECT
  TASK
}

// =====================================================================
// CORE / IDENTITY
// =====================================================================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  // Nullable: accounts created via Google sign-in (role GUEST) have no local password —
  // they authenticate only through the OAuth provider. Password login rejects a null hash.
  passwordHash String?
  // Google account subject (the stable per-user `sub` claim). Set when a user signs in with
  // Google; unique so an account binds to exactly one Google identity. Null for password users.
  googleSub    String?  @unique
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  // Bumped to revoke every outstanding token for this user (logout, password change/reset,
  // deactivation). Access/refresh tokens embed the tv they were minted at; requireAuth
  // rejects any token whose tv is stale.
  tokenVersion Int      @default(0)
  changesSeenAt DateTime? // last time this user viewed the change-notification feed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  managedProjects   Project[]       @relation("ProjectManager")
  charters          ProjectCharter[] @relation("CharterPM")
  ownedRisks        Risk[]          @relation("RiskOwner")
  ownedIssues       Issue[]         @relation("IssueOwner")
  ownedAssumptions  Assumption[]        @relation("AssumptionOwner")
  ownedDependencies ProjectDependency[] @relation("DependencyOwner")
  assignedTasks     Task[]          @relation("TaskPIC")
  manpowerItems     CostItemDirect[] @relation("ManpowerResource")
  auditLogs         AuditLog[]
  changeRequests    ChangeRequest[] @relation("CRRequester")
  reviewedCRs       ChangeRequest[] @relation("CRReviewer")
  decidedCRs        ChangeRequest[] @relation("CRDecider")
  resourceProfiles  Resource[]      @relation("ResourceUser")
  assignedBacklog   BacklogItem[]   @relation("BacklogAssignee")
  notifications     Notification[]  @relation("UserNotifications")
  refreshTokens     RefreshToken[]  @relation("UserRefreshTokens")

  @@index([role])
}

// One row per issued refresh token (id = the token's jti). Refresh tokens ROTATE:
// each /auth/refresh revokes the presented token and mints a new one. Replaying an
// already-revoked token signals theft, so the whole session family is revoked.
model RefreshToken {
  id           String    @id @default(uuid()) // jti embedded in the signed refresh token
  userId       String
  user         User      @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime  // mirrors the JWT exp; expired rows are prunable
  revokedAt    DateTime? // set when rotated away or explicitly revoked (logout/pw-change)
  replacedById String?   // the jti this token was rotated into (audit chain)
  createdAt    DateTime  @default(now())

  @@index([userId])
}

// =====================================================================
// PROJECT + CHARTER (Module 1)
// =====================================================================

model Project {
  id        String        @id @default(uuid())
  code      String        @unique
  name      String
  clientName String?      // the client/customer the project is delivered for
  sponsor   String?
  category        ProjectCategory?
  categoryOther   String?  // free-text detail, required only when category = OTHER
  costBaselineIdr Decimal? @db.Decimal(18, 2) // high-level planning cost baseline
  totalRevenueIdr Decimal? @db.Decimal(18, 2) // expected total revenue
  status    ProjectStatus @default(DRAFT)
  deliveryApproach DeliveryApproach @default(PREDICTIVE)
  pmUserId  String?
  pm        User?         @relation("ProjectManager", fields: [pmUserId], references: [id])
  // When set, this is a personal (guest) project owned by that user. Only the owner can see
  // or manage it (full sandbox); the corporate portfolio excludes personalOwnerId != null.
  // The owner self-governs it with no approval matrix. NULL = a normal corporate project.
  personalOwnerId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  scheduleBaselinedAt DateTime? // when the schedule baseline was last captured
  closedAt    DateTime?    // when the project moved to CLOSED
  closedById  String?      // actor who closed it (plain id, no FK — kept light)
  closureNote String?      // closure summary, or the mandatory reason for a force-close
  onHoldReason String?     // why the project is currently ON_HOLD (cleared on resume)
  // When set, the cost/schedule baseline (PMB/BAC) is frozen: cost lines, management
  // reserve, WBS tasks and the schedule baseline cannot be changed. Progress/actuals and
  // the risk register stay editable. ADMIN/PMO unlock (with a reason) to make baseline changes.
  baselineLockedAt   DateTime?
  baselineLockedById String?
  // Stamped once when the project first becomes activation-ready (all baselines set) and
  // ADMIN/PMO have been notified — so the "ready to activate" alert fires only once.
  activationReadyNotifiedAt DateTime?
  // When true, logging/editing/deleting a man-day auto-refreshes the single labour Actual
  // Cost entry (Σ consumed md × day-rate) so AC stays in sync with timesheets without a
  // manual "Fill AC" click. Default off — labour AC stays manual (one-click fill).
  autoPostLabourAc Boolean @default(false)

  charter          ProjectCharter?
  charterVersions  CharterVersion[]
  directCosts      CostItemDirect[]
  indirectCosts    CostItemIndirect[]
  risks            Risk[]
  issues           Issue[]
  tasks            Task[]
  costBaseline     CostBaseline?
  changeRequests   ChangeRequest[]
  attachments      Attachment[]
  actualCosts      ActualCostEntry[]
  sprints          Sprint[]
  backlogItems     BacklogItem[]
  mandayEntries    MandayEntry[]
  lessons          LessonLearned[]
  acceptances      AcceptanceSignoff[]
  stakeholders     Stakeholder[]
  procurements     Procurement[]
  assumptions      Assumption[]
  dependencies     ProjectDependency[]
  evmSnapshots     EvmSnapshot[]
  uatTestCases     UatTestCase[]
  kickoffMeeting   KickoffMeeting?
  bookmarks        ProjectBookmark[]
  requirements     Requirement[]

  @@index([status])
  @@index([pmUserId])
  // Guest-sandbox scoping filters on personalOwnerId in nearly every list/aggregate query
  // (portfolio, notifications, resource capacity, EVM trend, audit) — index the hot filter.
  @@index([personalOwnerId])
}

// Per-user project bookmark (personal "pin to top" flag). userId is stored FK-less
// (kept light, like closedById); the project relation cascades so a deleted project
// drops its bookmarks. One row per (user, project).
model ProjectBookmark {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model ProjectCharter {
  id              String          @id @default(uuid())
  projectId       String          @unique
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  description     String
  goals           String
  category        ProjectCategory
  categoryOther   String?         // free-text detail, required only when category = OTHER
  hiScope         String
  hiCostIdr       Decimal         @db.Decimal(18, 2)
  hiScheduleStart DateTime
  hiScheduleEnd   DateTime
  hiDeliverables  String

  pmUserId        String
  pm              User            @relation("CharterPM", fields: [pmUserId], references: [id])

  version         Int             @default(1)
  locked          Boolean         @default(false)
  committedAt     DateTime?
  committedBy     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
}

// Immutable snapshot taken on each Commit (versioning + audit)
model CharterVersion {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json
  committedBy String
  committedAt DateTime @default(now())

  @@unique([projectId, version])
  @@index([projectId])
}

// =====================================================================
// COST MANAGEMENT (Module 2)
// =====================================================================

// Unified Direct Cost line (Material rows + Manpower rows), discriminated by `type`
model CostItemDirect {
  id        String         @id @default(uuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      DirectCostType
  label     String
  // Free-text classification for type = OTHER (e.g. "Insurance", "Legal"); null otherwise.
  subCategory String?

  // --- Material fields (every non-MANPOWER type: TECHNOLOGY_*, HARDWARE_*, SOFTWARE_LICENSE, SUBCONTRACTOR, TRAINING_CERTIFICATION, SUPPORT_MAINTENANCE, OTHER) ---
  qty       Decimal?       @db.Decimal(18, 2)
  unitCost  Decimal?       @db.Decimal(18, 2)
  amount    Decimal?       @db.Decimal(18, 2) // = qty * unitCost

  // --- Manpower fields (type = MANPOWER) ---
  personnelRole     PersonnelRole?
  resourceUserId    String?
  resource          User?          @relation("ManpowerResource", fields: [resourceUserId], references: [id])
  rateCardId        String?
  rateCard          RateCard?      @relation(fields: [rateCardId], references: [id])
  unitCostPerManday Decimal?       @db.Decimal(18, 2)
  planMandays       Decimal?       @db.Decimal(10, 2)
  manpowerCost      Decimal?       @db.Decimal(18, 2) // = unitCostPerManday * planMandays

  // Link to schedule task (manpower <-> schedule sync)
  task   Task?   @relation("TaskManpower", fields: [taskId], references: [id])
  taskId String?

  // Link to the resource master (manpower pool). Preferred over the legacy
  // resourceUserId; supplies the day-rate and personnel role.
  resourceRef Resource? @relation("LineResource", fields: [resourceId], references: [id])
  resourceId  String?

  // Timesheet: actual man-days logged against this manpower line.
  mandayEntries MandayEntry[] @relation("LineTimesheet")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, type])
}

model CostItemIndirect {
  id          String           @id @default(uuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        IndirectCostType
  description String
  // Free-text classification for type = OTHER (e.g. "Insurance", "Bank charges"); null otherwise.
  subCategory String?
  amount      Decimal          @db.Decimal(18, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([projectId, type])
}

model RateCard {
  id                String           @id @default(uuid())
  roleName          String
  level             String?
  unitCostPerManday Decimal          @db.Decimal(18, 2)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // When set, this rate card is PRIVATE to a guest's personal workspace (their user id).
  // NULL = a corporate rate card. Uniqueness of (roleName, level) is enforced per-owner in
  // the service (a guest may reuse a role/level name that corporate also uses).
  personalOwnerId String?

  directCosts CostItemDirect[]
  resources   Resource[]

  @@index([personalOwnerId])
}

// ---------------------------------------------------------------------------
// Resource master (manpower pool). A Resource is a person or a generic role
// available to projects; it is NOT a login account (optionally linked to one
// via userId). Picked when loading manpower into the WBS / Cost module.
// ---------------------------------------------------------------------------
enum ResourceType {
  NAMED // a specific person
  GENERIC // a role / placeholder (e.g. "Senior QA Engineer")
}

model Resource {
  id            String        @id @default(uuid())
  name          String
  resourceType  ResourceType  @default(NAMED)
  roleTitle     String? // free-text job title, e.g. "Backend Engineer"
  personnelRole PersonnelRole @default(PROJECT_PERSONNEL)

  // Costing: an effective day-rate, optionally sourced from a rate card.
  rateCardId        String?
  rateCard          RateCard? @relation(fields: [rateCardId], references: [id])
  unitCostPerManday Decimal   @default(0) @db.Decimal(18, 2)

  // Capacity: mandays available per working day (0.5 = half-time, 3 = a crew of 3).
  capacityPerDay Decimal @default(1) @db.Decimal(6, 2)

  department String?

  // When set, this resource is PRIVATE to a guest's personal workspace (their user id).
  // NULL = a corporate resource. A guest only ever sees/manages their own; corporate roles
  // never see a guest's; and a resource may only be linked to a project with the same owner.
  personalOwnerId String?

  // Optional link to a system account (for resources who also log in).
  userId String?
  user   User?   @relation("ResourceUser", fields: [userId], references: [id])

  costLines CostItemDirect[] @relation("LineResource")
  picTasks  Task[]           @relation("TaskPicResource")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([personalOwnerId])
}

// Computed roll-up cache (1:1 with Project)
model CostBaseline {
  id                 String   @id @default(uuid())
  projectId          String   @unique
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  directTotal        Decimal  @default(0) @db.Decimal(18, 2)
  indirectTotal      Decimal  @default(0) @db.Decimal(18, 2)
  contingencyReserve Decimal  @default(0) @db.Decimal(18, 2)
  managementReserve  Decimal  @default(0) @db.Decimal(18, 2)
  costBaseline       Decimal  @default(0) @db.Decimal(18, 2) // direct + indirect + contingency
  budgetAtCompletion Decimal  @default(0) @db.Decimal(18, 2) // costBaseline + managementReserve

  updatedAt          DateTime @updatedAt
}

// Time-phased Actual Cost (AC) entries — cumulative AC up to a status date
// drives the Cost Performance Index (CPI) in EVM.
model ActualCostEntry {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date        DateTime
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  // Which budget this spend draws down (direct vs indirect). Defaults to DIRECT:
  // existing rows + labour-from-timesheet are direct; the AC form can set INDIRECT.
  category    CostCategory @default(DIRECT)
  recordedBy  String?
  createdAt   DateTime @default(now())

  @@index([projectId, date])
}

// Timesheet: actual man-days consumed, logged against a MANPOWER cost line
// (which carries the resource + task + project). Time-phased like ActualCostEntry.
// Consumed effort per resource = Σ mandays over that resource's lines.
model MandayEntry {
  id         String         @id @default(uuid())
  projectId  String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costItemId String
  costItem   CostItemDirect @relation("LineTimesheet", fields: [costItemId], references: [id], onDelete: Cascade)
  date       DateTime
  mandays    Decimal        @db.Decimal(10, 2)
  note       String?
  recordedBy String?
  createdAt  DateTime       @default(now())

  @@index([projectId, date])
  @@index([costItemId])
}

// =====================================================================
// RISK MANAGEMENT (Module 3)
// =====================================================================

model Risk {
  id          String     @id @default(uuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?
  category    String?
  status      RiskStatus @default(IDENTIFIED)
  kind        RiskKind   @default(THREAT)

  ownerUserId String?
  owner       User?      @relation("RiskOwner", fields: [ownerUserId], references: [id])

  // --- Qualitative ---
  probabilityScore Int          // 1..5
  impactScore      Int          // 1..5
  riskScore        Int          // = probabilityScore * impactScore
  severity         RiskSeverity

  // --- Quantitative (EMV) ---
  probabilityPct Decimal  @db.Decimal(5, 4) // 0..1
  impactCostIdr  Decimal  @db.Decimal(18, 2)
  emv            Decimal  @db.Decimal(18, 2) // = probabilityPct * impactCostIdr

  // --- Response ---
  responseStrategy ResponseStrategy?
  responseCost     Decimal?          @db.Decimal(18, 2)
  residualEmv      Decimal?          @db.Decimal(18, 2)
  includeInReserve Boolean           @default(true)

  attachments Attachment[] @relation("RiskAttachments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, severity])
}

enum IssueImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Issue Log — problems that have already occurred (distinct from Risk, which is
// a potential future event). Lightweight register: no EVM/reserve impact.
model Issue {
  id          String      @id @default(uuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?
  category    String?
  impact      IssueImpact @default(MEDIUM)
  status      IssueStatus @default(OPEN)

  ownerUserId String?
  owner       User?       @relation("IssueOwner", fields: [ownerUserId], references: [id])

  resolution  String?     @db.Text
  raisedAt    DateTime    @default(now()) // when the issue was logged/occurred
  resolvedAt  DateTime?                   // auto-stamped when status → RESOLVED/CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

// =====================================================================
// STAKEHOLDER MANAGEMENT (PMBOK Stakeholder KA)
// =====================================================================

enum StakeholderCategory {
  SPONSOR
  CUSTOMER
  TEAM
  VENDOR
  REGULATOR
  END_USER
  OTHER
}

// Power & interest for the power/interest grid.
enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
}

// PMBOK engagement assessment matrix (ordered UNAWARE < RESISTANT < NEUTRAL <
// SUPPORTIVE < LEADING) — captured as current vs desired to surface the gap.
enum EngagementLevel {
  UNAWARE
  RESISTANT
  NEUTRAL
  SUPPORTIVE
  LEADING
}

// Stakeholder register — who has a stake, their power/interest, and the current
// vs desired engagement so the PM can plan engagement effort where the gap is.
model Stakeholder {
  id                String              @id @default(uuid())
  projectId         String
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code              String
  name              String
  role              String? // title / role, e.g. "IT Director"
  organization      String?
  category          StakeholderCategory @default(OTHER)
  power             InfluenceLevel      @default(MEDIUM)
  interest          InfluenceLevel      @default(MEDIUM)
  currentEngagement EngagementLevel     @default(NEUTRAL)
  desiredEngagement EngagementLevel     @default(SUPPORTIVE)
  email             String?
  strategy          String?             @db.Text // engagement / communication approach
  notes             String?             @db.Text

  createdById String? // FK-less (kept light, like closeout artifacts)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId])
}

// =====================================================================
// PROCUREMENT MANAGEMENT (PMBOK Procurement KA)
// =====================================================================

enum ContractType {
  FIXED_PRICE
  TIME_AND_MATERIALS
  COST_PLUS
  PURCHASE_ORDER
}

enum ProcurementStatus {
  PLANNED
  SOLICITATION
  AWARDED
  IN_PROGRESS
  DELIVERED
  CLOSED
  CANCELLED
}

// Procurement / contract register — planned buys, vendors, contract type, value
// and status through the make-or-buy → solicit → award → deliver → close lifecycle.
model Procurement {
  id            String            @id @default(uuid())
  projectId     String
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code          String
  title         String
  vendor        String?
  vendorContact String?
  type          ContractType      @default(PURCHASE_ORDER)
  status        ProcurementStatus @default(PLANNED)
  amount        Decimal?          @db.Decimal(18, 2) // contract value (IDR)
  needBy        DateTime?
  startDate     DateTime?
  endDate       DateTime?
  scope         String?           @db.Text // SOW / what is procured
  notes         String?           @db.Text

  createdById String? // FK-less (kept light)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

// =====================================================================
// RAID — Assumptions & Dependencies (completes RAID with Risk + Issue)
// =====================================================================

enum AssumptionStatus {
  OPEN
  VALIDATED
  INVALIDATED
}

// Assumption register — things taken as true for planning; each gets validated
// or invalidated over time (an invalidated assumption often becomes a risk/issue).
model Assumption {
  id          String           @id @default(uuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String
  statement   String           @db.Text
  category    String?
  status      AssumptionStatus @default(OPEN)
  impact      IssueImpact      @default(MEDIUM) // impact if it proves false
  ownerUserId String?
  owner       User?            @relation("AssumptionOwner", fields: [ownerUserId], references: [id])
  notes       String?          @db.Text

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

// Direction of a cross-team / external dependency.
enum DependencyDirection {
  INBOUND // we need something from someone else
  OUTBOUND // someone else needs something from us
}

enum DependencyStatus {
  PENDING
  ON_TRACK
  AT_RISK
  RESOLVED
}

// Project-level dependency register (RAID "D") — external/cross-team dependencies,
// distinct from TaskDependency (the intra-schedule FS/SS/FF/SF links used by CPM).
model ProjectDependency {
  id           String              @id @default(uuid())
  projectId    String
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code         String
  description  String              @db.Text
  direction    DependencyDirection @default(INBOUND)
  counterparty String? // the other team / project / vendor
  dueDate      DateTime?
  status       DependencyStatus    @default(PENDING)
  impact       IssueImpact         @default(MEDIUM) // criticality
  ownerUserId  String?
  owner        User?               @relation("DependencyOwner", fields: [ownerUserId], references: [id])
  notes        String?             @db.Text

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId, status])
}

// =====================================================================
// SCHEDULE MANAGEMENT (Module 4)
// =====================================================================

model Task {
  id           String    @id @default(uuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentTaskId String?
  parent       Task?     @relation("TaskTree", fields: [parentTaskId], references: [id])
  subtasks     Task[]    @relation("TaskTree")

  wbsCode      String
  name         String
  // WBS dictionary — descriptive detail for each work package.
  description        String? @db.Text
  deliverable        String? @db.Text
  acceptanceCriteria String? @db.Text
  planStart    DateTime
  planEnd      DateTime
  // Schedule baseline snapshot (for variance / tracking Gantt).
  baselineStart  DateTime?
  baselineFinish DateTime?
  actualStart  DateTime?
  actualFinish DateTime?

  picUserId    String?
  pic          User?     @relation("TaskPIC", fields: [picUserId], references: [id])

  // Owner / person-in-charge picked from the resource master (preferred over picUserId).
  picResourceId String?
  picResource   Resource? @relation("TaskPicResource", fields: [picResourceId], references: [id])

  progressPct  Int       @default(0) // 0..100
  isMilestone  Boolean   @default(false)
  sortOrder    Int       @default(0)

  // schedule <-> cost (manpower) link
  manpowerItems CostItemDirect[] @relation("TaskManpower")

  // dependencies
  predecessorOf TaskDependency[] @relation("DepPredecessor")
  successorOf   TaskDependency[] @relation("DepSuccessor")

  // requirements traceability (which requirements this work delivers)
  requirementLinks RequirementTaskLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, parentTaskId])
}

model TaskDependency {
  id            String         @id @default(uuid())
  predecessorId String
  predecessor   Task           @relation("DepPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     Task           @relation("DepSuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  type          DependencyType @default(FS)
  lagDays       Int            @default(0)

  @@unique([predecessorId, successorId])
}

// =====================================================================
// GOVERNANCE: CHANGE CONTROL, AUDIT, ATTACHMENTS
// =====================================================================

model ChangeRequest {
  id          String              @id @default(uuid())
  projectId   String
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String // e.g. CHARTER, COST_BASELINE, SCHEDULE, SCOPE
  title       String
  description String

  chargeable  Boolean             @default(false) // paid (billable) vs no-cost change
  amountIdr   Decimal?            @db.Decimal(18, 2) // billable amount (only when chargeable)
  magnitude   ChangeMagnitude     @default(MINOR)
  impactAreas ChangeImpact[]      // areas affected: cost/schedule/resource/quality/risk

  status      ChangeRequestStatus @default(SUBMITTED)
  requestedBy String
  requester   User                @relation("CRRequester", fields: [requestedBy], references: [id])
  reviewedBy  String?
  reviewer    User?               @relation("CRReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  decidedBy   String?
  decider     User?               @relation("CRDecider", fields: [decidedBy], references: [id])
  decidedAt   DateTime?

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([projectId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  projectId String? // set for project-scoped events (enables per-project audit view)
  entity    String
  entityId  String
  action    String // CREATE | UPDATE | DELETE | COMMIT | APPROVE | REJECT
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([projectId, createdAt])
  @@index([createdAt])
}

model Attachment {
  id         String          @id @default(uuid())
  ownerType  AttachmentOwner
  ownerId    String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  uploadedBy String
  createdAt  DateTime        @default(now())

  // optional typed back-relations (kept loose/polymorphic by ownerType)
  project    Project? @relation(fields: [projectRelId], references: [id])
  projectRelId String?
  risk       Risk?    @relation("RiskAttachments", fields: [riskRelId], references: [id])
  riskRelId  String?

  @@index([ownerType, ownerId])
}

// ---- Agile ----

// A time-boxed iteration (Scrum). Optional for Kanban projects (items can live in
// the product backlog / on the board without a sprint).
model Sprint {
  id        String       @id @default(uuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  name      String
  goal      String?      @db.Text
  startDate DateTime?
  endDate   DateTime?
  status    SprintStatus @default(PLANNED)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items     BacklogItem[]
  snapshots SprintSnapshot[]

  @@index([projectId])
}

// Daily snapshot of a sprint's remaining vs committed story points — powers the
// burndown chart (recorded when the board is fetched, deduped per day).
model SprintSnapshot {
  id               String   @id @default(uuid())
  sprintId         String
  sprint           Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  date             DateTime @db.Date
  committedPoints  Int      @default(0)
  remainingPoints  Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([sprintId, date])
  @@index([sprintId])
}

// A point-in-time capture of a project's EVM metrics. Progress (progressPct) is only
// a "now" value, so Earned Value cannot be reconstructed for past dates — capturing a
// snapshot freezes PV/EV/AC/CPI/SPI as-of a status date, turning the app's point-in-time
// EVM into a trend (the CPR/IPMR-style S-curve of EV & the CPI/SPI history over time).
// One snapshot per (project, statusDate); re-capturing the same date upserts.
model EvmSnapshot {
  id               String   @id @default(uuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusDate       DateTime @db.Date
  bac              Decimal  @db.Decimal(18, 2)
  pv               Decimal  @db.Decimal(18, 2)
  ev               Decimal  @db.Decimal(18, 2)
  ac               Decimal  @db.Decimal(18, 2)
  cpi              Float    @default(0)
  spi              Float    @default(0)
  weightedProgress Float    @default(0) // physical % complete (0..1) at the status date
  note             String?
  createdById      String?  // actor who captured it (plain id, no FK — kept light)
  createdAt        DateTime @default(now())

  @@unique([projectId, statusDate])
  @@index([projectId, statusDate])
}

// Persistent per-user in-app notification (inbox) — for discrete events like being
// assigned as a project's PM (not the on-demand "needs attention" alerts).
model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id])
  type      String    // e.g. PROJECT_ASSIGNED
  title     String
  body      String?   @db.Text
  projectId String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

// A product-backlog work item (epic/story/task/bug). `sprintId` null = product
// backlog; when in a sprint it shows on the board by `status`.
model BacklogItem {
  id                 String        @id @default(uuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id])
  sprintId           String?
  sprint             Sprint?       @relation(fields: [sprintId], references: [id])
  type               BacklogType   @default(STORY)
  title              String
  description        String?       @db.Text
  acceptanceCriteria String?       @db.Text
  storyPoints        Int?
  priority           Int           @default(0) // MoSCoW-ish rank; lower = higher priority
  status             BacklogStatus @default(TODO)
  assigneeUserId     String?
  assignee           User?         @relation("BacklogAssignee", fields: [assigneeUserId], references: [id])
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([projectId])
  @@index([sprintId])
}

// --- Closing artifacts (PMBOK Close-Project process) -------------------------
// Captured during/at project closeout: a lessons-learned register + formal
// deliverable acceptance sign-offs. Both surface as advisory items on the
// closure-readiness checklist (they never hard-block closure — only schedule
// completeness does, per the PMO policy).

enum LessonCategory {
  WENT_WELL      // what worked and should be repeated
  WENT_WRONG     // what to avoid next time
  RECOMMENDATION // an action/improvement for future projects
}

enum AcceptanceDecision {
  ACCEPTED
  ACCEPTED_WITH_CONDITIONS
  REJECTED
}

// A single entry in the project's lessons-learned register.
model LessonLearned {
  id          String         @id @default(uuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    LessonCategory @default(RECOMMENDATION)
  title       String
  description String?        @db.Text
  createdById String?        // actor who logged it (plain id, no FK — name resolved in the service)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
}

// A formal acceptance sign-off from an accepting party (sponsor, customer, …).
// The signer may be external, so the name is free text; recordedById is the
// system user who logged the sign-off.
model AcceptanceSignoff {
  id           String             @id @default(uuid())
  projectId    String
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  party        String             // who accepts: e.g. "Sponsor", "Customer — Bank X"
  decision     AcceptanceDecision @default(ACCEPTED)
  signedByName String?            // named signer (may be external, not a system user)
  comments     String?            @db.Text
  recordedById String?            // system user who logged it (plain id, name resolved in the service)
  signedAt     DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([projectId])
}

// User Acceptance Test case — a structured, executable UAT template per project.
enum UatStatus {
  NOT_RUN
  PASS
  FAIL
  BLOCKED
}

model UatTestCase {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String // per-project code, e.g. UAT-001
  title       String
  scenario    String?   @db.Text // context / preconditions (given)
  steps       String?   @db.Text // steps to execute (when)
  expected    String    @db.Text // expected result (then)
  actual      String?   @db.Text // actual result on execution
  status      UatStatus @default(NOT_RUN)
  testerName  String? // who ran it (free text; may be an external UAT tester)
  executedAt  DateTime?
  notes       String?   @db.Text // defect reference / remarks
  sortOrder   Int       @default(0)
  createdById String? // actor who created it (plain id, no FK — name resolved in the service)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

// Kick-Off Meeting minutes — one structured record per project (Initiating artifact).
model KickoffMeeting {
  id          String              @id @default(uuid())
  projectId   String              @unique
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meetingDate DateTime?
  location    String? // e.g. "Online (Teams)" / "HQ Room 3A"
  facilitator String?
  agenda      String?             @db.Text
  objectives  String?             @db.Text
  decisions   String?             @db.Text
  notes       String?             @db.Text
  attendees   KickoffAttendee[]
  actionItems KickoffActionItem[]
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model KickoffAttendee {
  id        String         @id @default(uuid())
  meetingId String
  meeting   KickoffMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name      String
  role      String? // role / organization
  present   Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([meetingId])
}

enum KickoffActionStatus {
  OPEN
  DONE
}

model KickoffActionItem {
  id          String              @id @default(uuid())
  meetingId   String
  meeting     KickoffMeeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  description String              @db.Text
  ownerName   String?
  dueDate     DateTime?
  status      KickoffActionStatus @default(OPEN)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([meetingId])
}

// ---------------------------------------------------------------------------
// Requirements traceability (RTM) — a scope register linked to the WBS work
// that delivers each requirement, yielding a coverage matrix + scope-gap view.
// ---------------------------------------------------------------------------

enum RequirementCategory {
  FUNCTIONAL
  NON_FUNCTIONAL
  BUSINESS
  TECHNICAL
  REGULATORY
  OTHER
}

// MoSCoW prioritisation.
enum RequirementPriority {
  MUST
  SHOULD
  COULD
  WONT
}

enum RequirementStatus {
  PROPOSED
  APPROVED
  IN_PROGRESS
  VERIFIED
  DEFERRED
  REJECTED
}

model Requirement {
  id                 String              @id @default(uuid())
  projectId          String
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code               String // REQ-001, REQ-002, …
  title              String
  description        String?             @db.Text
  category           RequirementCategory @default(FUNCTIONAL)
  priority           RequirementPriority @default(MUST)
  status             RequirementStatus   @default(PROPOSED)
  source             String? // origin: stakeholder, document, charter clause…
  acceptanceCriteria String?             @db.Text
  notes              String?             @db.Text

  taskLinks RequirementTaskLink[]

  createdById String? // FK-less (kept light, like the other registers)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId])
}

// Forward traceability: requirement -> the WBS task(s) that deliver it.
model RequirementTaskLink {
  id            String      @id @default(uuid())
  requirementId String
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([requirementId, taskId])
  @@index([requirementId])
  @@index([taskId])
}
