# PostgreSQL connection (Prisma)
DATABASE_URL="postgresql://prima:prima@localhost:5432/prima_pm?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# App
PORT=4000
NODE_ENV=development

# Optional open-registration paths (both OFF unless set)
# GUEST_SIGNUP_ENABLED=true            # self-service guest signup (POST /auth/guest/register)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com   # "Sign in with Google" → sandboxed GUEST
#   Create an OAuth 2.0 Web client in Google Cloud Console; add your site to Authorized
#   JavaScript origins (e.g. https://your-domain). The client ID is public (ships in the browser).
